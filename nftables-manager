menu_loop() {
  while true; do
    cat <<'EOF_MENU'

==== nftables manager (safe) ====
1) 状态
2) 编辑 settings.conf
3) 编辑 allow.list
4) 编辑 forward.list
5) 编辑 management.list
6) 预览编译规则
7) 应用规则
8) 回滚到最近可用规则
9) 安装 systemd service
10) 卸载 systemd service
11) 创建备份
12) 恢复最近备份
0) 退出
EOF_MENU
    read -r -p '选择: ' choice
    case "$choice" in
      1) show_status ;;
      2) edit_file "$SETTINGS_FILE" ;;
      3) edit_file "$ALLOW_FILE" ;;
      4) edit_file "$FORWARD_FILE" ;;
      5) edit_file "$MANAGEMENT_FILE" ;;
      6) preview_ruleset ;;
      7) apply_rules ;;
      8) rollback_last_active ;;
      9) install_service ;;
      10) uninstall_service ;;
      11) backup_configs ;;
      12) restore_latest_backup ;;
      0) break ;;
      *) log_warn "无效选择。" ;;
    esac
  done
}

main() {
  require_root
  require_cmd nft
  acquire_global_lock || die "已有另一个 nft_manager 实例在运行。"
  load_settings
  ensure_dirs_and_files
  warn_nat_conflict

  case "${1:-menu}" in
    init)
      save_settings
      regenerate_auto_rescue_file
      write_loader_script
      log_ok "初始化完成。"
      ;;
    preview)
      preview_ruleset
      ;;
    apply)
      apply_rules
      ;;
    rollback)
      rollback_last_active
      ;;
    status)
      show_status
      ;;
    install-service)
      install_service
      ;;
    uninstall-service)
      uninstall_service
      ;;
    backup)
      backup_configs
      ;;
    restore-latest)
      restore_latest_backup
      ;;
    edit)
      case "${2:-}" in
        settings) edit_file "$SETTINGS_FILE" ;;
        allow) edit_file "$ALLOW_FILE" ;;
        allow-range) edit_file "$ALLOW_RANGE_FILE" ;;
        acl) edit_file "$ALLOW_ACL_FILE" ;;
        forward) edit_file "$FORWARD_FILE" ;;
        block-ip) edit_file "$BLOCK_IP_FILE" ;;
        block-port) edit_file "$BLOCK_PORT_FILE" ;;
        ratelimit) edit_file "$RATELIMIT_FILE" ;;
        connlimit) edit_file "$CONNLIMIT_FILE" ;;
        trace) edit_file "$TRACE_FILE" ;;
        management) edit_file "$MANAGEMENT_FILE" ;;
        auto-rescue) edit_file "$AUTO_RESCUE_FILE" ;;
        *) show_help; exit 1 ;;
      esac
      ;;
    menu)
      menu_loop
      ;;
    -h|--help|help)
      show_help
      ;;
    *)
      show_help
      exit 1
      ;;
  esac
}

main "$@"
